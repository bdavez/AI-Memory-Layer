# backend/api_memory.py

from flask import Blueprint, request, jsonify

from .memory_store import memory_store
from .memory_settings import load_settings, save_settings

# IMPORTANT:
# Do NOT import run_memory_summarizer directly.
# We dynamically reload memory_summarizer to avoid circular imports
# and stale function references.
import importlib
from . import memory_summarizer

bp = Blueprint("memory", __name__, url_prefix="/api/memory")


# ------------------------------
# Events
# ------------------------------
@bp.route("/events", methods=["POST"])
def add_event():
    data = request.get_json(force=True) or {}
    user_id = data.get("user_id")
    session_id = data.get("session_id")
    role = data.get("role")
    content = data.get("content")
    metadata = data.get("metadata") or {}

    if not user_id or not session_id or not role or content is None:
        return jsonify({"error": "user_id, session_id, role, content required"}), 400

    evt = memory_store.add_event(user_id, session_id, role, content, metadata)
    return jsonify(evt), 201


# ------------------------------
# Facts
# ------------------------------
@bp.route("/facts", methods=["GET"])
def list_facts():
    user_id = request.args.get("user_id")
    facts = memory_store.list_facts()
    return jsonify({"facts": facts}), 200


@bp.route("/facts/<int:index>", methods=["DELETE"])
def delete_fact(index):
    memory_store.delete_fact(index)
    return jsonify({"status": "ok"}), 200


# ------------------------------
# Settings (auto/manual toggle)
# ------------------------------
@bp.route("/settings", methods=["GET"])
def get_memory_settings():
    return jsonify(load_settings()), 200


@bp.route("/settings", methods=["POST"])
def update_memory_settings():
    data = request.get_json(force=True) or {}
    settings = load_settings()

    if "auto_summarize" in data:
        settings["auto_summarize"] = bool(data["auto_summarize"])

    if "event_threshold" in data:
        settings["event_threshold"] = int(data["event_threshold"])

    save_settings(settings)
    return jsonify(settings), 200


# ------------------------------
# Summarizer
# ------------------------------
@bp.route("/summarize", methods=["POST"])
def summarize_memory():
    print("[api_memory] summarize_memory called", flush=True)

    data = request.get_json(force=True) or {}
    user_id = data.get("user_id")

    if not user_id:
        return jsonify({"error": "user_id required"}), 400

    # Force reload of summarizer module to avoid stale function references
    importlib.reload(memory_summarizer)
    print("[api_memory] memory_summarizer reloaded", flush=True)

    job = memory_summarizer.run_memory_summarizer(user_id)
    print(f"[api_memory] run_memory_summarizer returned: {job}", flush=True)

    if job is None:
        return jsonify({"error": "no events to summarize"}), 400

    return jsonify({"job_id": job["id"]}), 202


# ------------------------------
# Ingest (worker callback)
# ------------------------------
@bp.route("/ingest", methods=["POST"])
def ingest_summary():
    data = request.get_json(force=True) or {}
    raw_text = data.get("text")

    if raw_text is None:
        return jsonify({"error": "text required"}), 400

    importlib.reload(memory_summarizer)
    facts = memory_summarizer.ingest_summarizer_output(raw_text)

    for f in facts:
        memory_store.add_fact(f)

    return jsonify({"added_facts": facts}), 201
