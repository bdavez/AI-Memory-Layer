#!/bin/bash

echo "🔍 Running post-merge metadata scan..."

ENCODED_PATTERNS=(
    "ZWRnZV9hbGxfb3Blbl90YWJz"
    "V2Vic2l0ZUNvbnRlbnRf"
    "VXNlcidzIEVkZ2UgYnJvd3NlciB0YWJzIG1ldGFkYXRh"
)

BAD_PATTERNS=()
for EP in "${ENCODED_PATTERNS[@]}"; do
    BAD_PATTERNS+=("$(echo "$EP" | base64 --decode)")
done

FILES=$(git ls-files)

FOUND=false

for FILE in $FILES; do
    if file "$FILE" | grep -qE 'text|ASCII'; then
        for PATTERN in "${BAD_PATTERNS[@]}"; do
            if grep -q "$PATTERN" "$FILE"; then
                echo "❌ WARNING: Copilot metadata detected in $FILE"
                echo "    Pattern: $PATTERN"
                FOUND=true
            fi
        done
    fi
done

if [ "$FOUND" = true ]; then
    echo ""
    echo "⚠️ ACTION REQUIRED:"
    echo "    Remove the metadata from the affected files."
    echo ""
else
    echo "✔ No metadata found. Merge clean."
fi