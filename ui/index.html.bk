<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Datacenter Control Plane</title>
  <link rel="stylesheet" href="css/neon.css" />
</head>

<body>
  <div id="app">

    <!-- HEADER -->
    <header class="cp-header">
      <div class="cp-title">DATACENTER CONTROL PLANE</div>
      <div class="cp-subtitle">Canonical State • Drift • Actions</div>
    </header>

    <!-- MAIN GRID -->
    <main class="cp-main">

      <!-- LEFT COLUMN — STATUS PANEL -->
      <section class="cp-status-panel">
        <h2>STATUS</h2>

        <!-- Machine Filters -->
        <div class="machine-selector">
          <label for="machine-select">Machine:</label>
          <select id="machine-select"></select>
        </div>

        <div class="machine-filters">
          <label><input type="checkbox" id="filter-alive" /> Alive only</label>
          <label><input type="checkbox" id="filter-gpu" /> GPU nodes</label>
          <label><input type="checkbox" id="filter-busy" /> Busy only</label>
          <label><input type="checkbox" id="filter-focus" /> Focus mode</label>
        </div>

        <!-- Status Indicator -->
        <div id="status-indicator" class="status-indicator status-unknown">
          <span class="status-label">Unknown</span>
        </div>

        <div id="status-details" class="status-details">Waiting for status…</div>

        <!-- GPU Cluster Summary -->
        <div id="gpu-cluster-summary" class="gpu-cluster-summary"></div>

        <!-- Machine Cards -->
        <div id="machine-table" class="machine-table"></div>

        <!-- Heartbeat Cards -->
        <h3>Machine Heartbeats</h3>
        <div id="heartbeat-pane" class="heartbeat-pane"></div>
      </section>

      <!-- RIGHT COLUMN — OPERATOR PANEL -->
      <section class="cp-operator-panel">
        <h2>OPERATOR ACTIONS</h2>

        <div class="button-bar">
          <button class="op-button" data-action="open-code-assistant">CODE ASSISTANT</button>
          <button class="op-button" data-action="view-memory">MEMORY</button>
          <button class="op-button" data-action="refresh-status">REFRESH STATUS</button>
          <button class="op-button" data-action="run-compile">RUN COMPILE</button>
          <button class="op-button" data-action="view-canonical">VIEW CANONICAL STATE</button>
          <button class="op-button" data-action="view-diff">VIEW DRIFT DIFF</button>
          <button class="op-button" data-action="view-vm-inventory">VIEW VM INVENTORY</button>
          <button class="op-button" data-action="view-storage-map">VIEW STORAGE MAP</button>
          <button class="op-button" data-action="view-compile-history">COMPILE HISTORY</button>
          <button class="op-button" data-action="view-jobs">JOBS</button>
        </div>

        <!-- MEMORY PANEL -->
        <div id="memory-pane" class="cp-operator-panel" style="display:none; margin-top:16px;">
          <h2>User Memory</h2>

          <div class="memory-controls">
            <button id="memory-refresh" class="op-button">Refresh</button>
            <button id="memory-summarize" class="op-button">Summarize Now</button>
            <button id="memory-clear" class="op-button danger">Clear All Facts</button>
          </div>

          <div id="memory-facts-container">
            <p>Loading memory…</p>
          </div>
        </div>

        <!-- JOBS PANEL -->
        <div id="jobs-pane" class="cp-operator-panel" style="display:none; margin-top:16px;">
          <h2>Jobs</h2>
          <div id="jobs-content">Loading jobs…</div>
        </div>

      </section>
    </main>

    <!-- MODAL SYSTEM -->
    <section id="modal-container" class="modal-container hidden">
      <div class="modal-backdrop"></div>
      <div class="modal">
        <div class="modal-header">
          <span id="modal-title">Modal Title</span>
          <button id="modal-close" class="modal-close">&times;</button>
        </div>
        <div id="modal-body" class="modal-body">Modal content goes here.</div>
        <div class="modal-footer">
          <button id="modal-download" class="modal-footer-button">Download JSON</button>
          <button id="modal-close-footer" class="modal-footer-button">Close</button>
        </div>
      </div>
    </section>

    <!-- CANONICAL DIFF MODAL -->
    <div id="canonical-diff-modal" class="modal hidden">
      <div class="modal-content neon-modal">
        <div class="modal-header">
          <h3>Canonical vs Live Diff</h3>
          <button id="btn-close-canonical-diff" class="modal-close">×</button>
        </div>
        <pre id="canonical-diff-json" class="json-viewer"></pre>
        <div class="modal-footer">
          <button id="btn-download-canonical-diff" class="op-btn">DOWNLOAD DIFF JSON</button>
          <button id="btn-close-canonical-diff-footer" class="op-btn">CLOSE</button>
        </div>
      </div>
    </div>

  </div>

  <!-- JS MODULES -->
  <script type="module" src="js/api.js"></script>
  <script type="module" src="js/status.js"></script>
  <script type="module" src="js/buttons.js"></script>
  <script type="module" src="js/modal.js"></script>
  <script type="module" src="js/jsonviewer.js"></script>
  <script type="module" src="js/diff.js"></script>
  <script type="module" src="js/main.js"></script>
  <script type="module" src="js/jobs.js"></script>
  <script type="module" src="js/memory.js"></script>

</body>
</html>
