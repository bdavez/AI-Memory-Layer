// ui/js/api.js
// Canonical API client for the Datacenter Control Plane
// ------------------------------
// ------------------------------
// Helper: JSON fetch wrapper
// ------------------------------
async function fetchJSON(url, options = {}) {
  const resp = await fetch(url, {
    headers: { "Content-Type": "application/json" },
    ...options,
  });

  if (!resp.ok) {
    const text = await resp.text();
    throw new Error(`HTTP ${resp.status}: ${text}`);
  }

  return resp.json();
}

// ------------------------------
// Existing Control Plane APIs
// ------------------------------
export async function apiGetStatus() {
  return fetchJSON("/status");
}

export async function apiRunCompile() {
  return fetchJSON("/compile", { method: "POST" });
}

export async function apiGetCanonical() {
  return fetchJSON("/canonical");
}

export async function apiGetVmInventory() {
  return fetchJSON("/vm-inventory");
}

export async function apiGetStorageMap() {
  return fetchJSON("/storage-map");
}

export async function apiGetCompileHistory() {
  return fetchJSON("/compile-history");
}

export async function apiGetDriftDiff() {
  return fetchJSON("/drift-diff");
}

export async function fetchCanonicalState() {
  return fetchJSON("/canonical");
}
// ------------------------------
// Memory API
// ------------------------------
export async function apiAddEvent(evt) {
  return fetchJSON("/api/memory/events", {
    method: "POST",
    body: JSON.stringify(evt),
  });
}

export async function apiGetFacts(userId) {
  return fetchJSON(`/api/memory/facts?user_id=${encodeURIComponent(userId)}`);
}
// ------------------------------
// Job System (LLM, Code Assist, Vision, Diffusion)
// ------------------------------
export async function createJob(jobType, model, input) {
  return fetchJSON("/api/jobs", {
    method: "POST",
    body: JSON.stringify({
      type: jobType,
      model,
      input,
    }),
  });
}

export async function getJob(jobId) {
  return fetchJSON(`/api/jobs/${jobId}`);
}

export function streamJob(jobId, onToken, onDone, onError) {
  const evtSource = new EventSource(`/api/jobs/${jobId}/stream`);

  evtSource.addEventListener("token", (ev) => {
    try {
      const data = JSON.parse(ev.data);
      onToken && onToken(data);
    } catch (e) {
      console.error("Failed to parse token event", e, ev.data);
    }
  });

  evtSource.addEventListener("done", () => {
    evtSource.close();
    onDone && onDone();
  });

  evtSource.addEventListener("error", (ev) => {
    console.error("Stream error", ev);
    evtSource.close();
    onError && onError(ev);
  });

  return evtSource;
}
