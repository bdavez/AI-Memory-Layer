
function openModalTree(title, jsonData) {
  window.__modalJsonData = jsonData;
  openModal(title, "");
  const body = document.getElementById("modal-body");
  body.innerHTML = "";
  body.appendChild(renderJsonTree(jsonData));
}

function renderJsonTree(obj) {
  const container = document.createElement("div");
  container.className = "json-tree";
  container.appendChild(renderNode(obj));
  return container;
}

function renderNode(value) {
  const el = document.createElement("div");
  el.className = "json-node";

  if (typeof value === "object" && value !== null) {
    const isArray = Array.isArray(value);
    const keys = Object.keys(value);

    const header = document.createElement("div");
    header.className = "json-node-header";
    header.textContent = isArray ? "[ ]" : "{ }";

    const children = document.createElement("div");
    children.className = "json-node-children";

    header.addEventListener("click", () => {
      children.classList.toggle("collapsed");
    });

    for (const key of keys) {
      const row = document.createElement("div");
      row.className = "json-row";

      const keyEl = document.createElement("span");
      keyEl.className = "json-key";
      keyEl.textContent = key + ": ";

      const valEl = renderNode(value[key]);

      row.appendChild(keyEl);
      row.appendChild(valEl);
      children.appendChild(row);
    }

    el.appendChild(header);
    el.appendChild(children);
    return el;
  }

  const val = document.createElement("span");
  val.className = "json-value";
  val.textContent = JSON.stringify(value);
  el.appendChild(val);
  return el;
}

function downloadJson(data) {
  const blob = new Blob([JSON.stringify(data, null, 2)], { type: "application/json" });
  const url = URL.createObjectURL(blob);
  const a = document.createElement("a");
  const ts = new Date().toISOString().replace(/[:.]/g, "-");
  a.href = url;
  a.download = `export-${ts}.json`;
  a.click();
  URL.revokeObjectURL(url);
}
